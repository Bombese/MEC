-------------------------------------------------
-- VARIABLES
-------------------------------------------------
local speed = 16
local jump = 50
local infJump = false
local espOn = false

-------------------------------------------------
-- APPLY
-------------------------------------------------
local function apply()
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.WalkSpeed = speed
            hum.JumpPower = jump
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.3)
    apply()
end)

